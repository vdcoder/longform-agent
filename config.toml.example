[llm]
base_url       = "http://localhost:8080/v1"   # any OpenAI-compatible endpoint
model          = "local"
api_key        = "not-needed"
max_tokens     = 4096
temperature    = 0.7
# llama.cpp KV-cache slot IDs — set to -1 to disable. Requires --parallel 2 on server.
chat_slot      = 0
summarize_slot = 1

[search]
max_results       = 5
max_snippet_chars = 300

[agent]
project_dir          = "project"  # directory containing bible.md, chapters/, etc.
keep_last_n          = 6          # verbatim turns kept in context window
max_full_chapters    = 0          # set > 0 to include full chapter text in system prompt
max_tool_iterations  = 6          # max tool calls per turn (safety cap)
memory_max_chars     = 4000       # rolling cap on agent_memory.md
summary_max_chars    = 3000       # rolling cap on conversation_summary.md
